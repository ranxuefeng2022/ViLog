{
  "coc.nodePath": "/home/ranxuefeng/.user/node-v24.11.1-linux-x64/bin/node",
  
  "diagnostic": {
    "enable": false,
    "level": "information",
    "enableSigns": false,
    "virtualText": false
  },
  
  "snippets": {
    "enable": true,
    "ultisnips": {
      "enable": true,
      "pythonPrompt": false
